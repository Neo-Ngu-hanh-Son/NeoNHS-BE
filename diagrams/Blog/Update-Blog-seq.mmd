---
config:
  theme: base
  themeVariables:
    primaryColor: "#ffffff"
    primaryTextColor: "#000000"
    primaryBorderColor: "#000000"
    activationBkgColor: "#eeeeee"
    activationBorderColor: "#000000"
    actorBkg: "#ffffff"
    actorTextColor: "#000000"
    actorBorder: "#000000"
    altBackground: "#f5f5f5"
    altBorder: "#000000"
  sequence:
    actorMargin: 5
    messageMargin: 5
---
sequenceDiagram
    actor Admin as Admin <br/> <<user>>
    participant AdminScreen as AdminScreen <br/> <<user interaction>>
    participant AdminBlogController as AdminBlogController <br/> <<controller>>
    participant BlogService as BlogService <br/> <<service>>
    participant BlogCategoryRepository as BlogCategoryRepository <br/> <<repository>>
    participant BlogRepository as BlogRepository <br/> <<repository>>
    participant DB

    Admin->>+AdminScreen: 1. Input update blog details
    AdminScreen->>+AdminBlogController: 2. updateBlog(blogId, blogRequest)
    AdminBlogController->>+BlogService: 3. updateBlog(blogId, blogRequest)
    
    %% Common Validation Box
    alt 4A Validation Failed
        BlogService-->>AdminBlogController: 4A1. Invalid Data
        AdminBlogController-->>AdminScreen: 4A2. Invalid Data, please try again later
        AdminScreen-->>Admin: 4A3. Show Invalid Data error
    else 4B Validation Passed
        BlogService->>+BlogRepository: 4B1. findById(blogId)
        BlogRepository->>+DB: 4B2. findById(blogId)
        DB-->>-BlogRepository: 4B3. Blog result
        BlogRepository-->>-BlogService: 4B4. Blog result
        
        alt 5A Blog not found
            BlogService-->>AdminBlogController: 5A1. Not Found
            AdminBlogController-->>AdminScreen: 5A2. Blog not found, please try again later
            AdminScreen-->>Admin: 5A3. Show Blog not found error
        else 5B Blog exists
            BlogService->>+BlogRepository: 5B1. findById(blogId)
            BlogRepository->>+DB: 5B2. findById(blogId)
            DB-->>-BlogRepository: 5B3. Blog result
            BlogRepository-->>-BlogService: 5B4. Blog result
            
            alt 6A Title already exists for another blog
                BlogService-->>AdminBlogController: 6A1. Duplicate Title
                AdminBlogController-->>AdminScreen: 6A2. Title already exists for another blog,<br/> please try again later
                AdminScreen-->>Admin: 6A3. Show title exists error
            else 6B Title details are unique
                BlogService->>BlogService: 6B1. Update fields
                BlogService->>+BlogRepository: 6B2. save(blog)
                BlogRepository->>+DB: 6B3. save(blog)
                DB-->>-BlogRepository: 6B4. Saved Entity
                BlogRepository-->>-BlogService: 6B5. Saved Entity
            end
        end
    end
    BlogService->>BlogService: 7. Map to Response
    BlogService-->>-AdminBlogController: 8. BlogResponse
    AdminBlogController-->>-AdminScreen: 9. Blog updated
    AdminScreen-->>-Admin: 10. Show blog updated message
