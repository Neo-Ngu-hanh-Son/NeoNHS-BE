---
config:
  theme: base
  themeVariables:
    primaryColor: "#ffffff"
    primaryTextColor: "#000000"
    primaryBorderColor: "#000000"
    activationBkgColor: "#eeeeee"
    activationBorderColor: "#000000"
    actorBkg: "#ffffff"
    actorTextColor: "#000000"
    actorBorder: "#000000"
    altBackground: "#f5f5f5"
    altBorder: "#000000"
  sequence:
    actorMargin: 10
    messageMargin: 0
---
sequenceDiagram
    actor Tourist as Tourist <br/> <<user>>
    participant GoogleLoginPage as GoogleLoginPage <br/> <<user interaction>>
    participant AuthController as AuthController <br/> <<coordinator>>
    participant AuthService as AuthService <br/> <<service>>
    participant GoogleTokenVerifier as GoogleTokenVerifier <br/> <<service>>
    participant UserRepository as UserRepository <br/> <<repository>>
    participant DB
    participant JwtTokenProvider as JwtTokenProvider <br/> <<service>>
    participant RedisAuthService as RedisAuthService <br/> <<service>>

    Tourist->>+GoogleLoginPage: 1. Sign in with Google
    GoogleLoginPage->>+AuthController: 2. googleLogin(idToken)
    AuthController->>+AuthService: 3. googleLogin(idToken)

    AuthService->>+GoogleTokenVerifier: 4. verify(idToken)
    GoogleTokenVerifier-->>-AuthService: 5. Payload

    alt 5A Verification failed
        AuthService-->>AuthController: 5A1. Verification failed
        AuthController-->>GoogleLoginPage: 5A2. Error response
        GoogleLoginPage-->>Tourist: 5A3. Show login error
    else 5B Verification passed
        AuthService->>+UserRepository: 5B1. findByEmail(email)
        UserRepository->>+DB: 5B2. findByEmail(email)
        DB-->>-UserRepository: 5B3. User result
        UserRepository-->>-AuthService: 5B4. User result
    end

    alt 6A User not found
        AuthService->>AuthService: 6A1. create new User from payload
        AuthService->>+UserRepository: 6A2. save(user)
        UserRepository->>+DB: 6A3. save(user)
        DB-->>-UserRepository: 6A4. Saved user
        UserRepository-->>-AuthService: 6A5. Saved user
    else 6B User found
        AuthService->>AuthService: 6B1. handle existing user
    end

    AuthService->>+JwtTokenProvider: 7. generateTokens(authentication)
    JwtTokenProvider-->>-AuthService: 8. Tokens

    AuthService->>+RedisAuthService: 9. saveRefreshToken(refreshToken, userId)
    RedisAuthService-->>-AuthService: 10. Saved successfully

    AuthService-->>-AuthController: 11. Saved successfully
    AuthController-->>-GoogleLoginPage: 12. Success response
    GoogleLoginPage-->>-Tourist: 13. Show success and redirect
