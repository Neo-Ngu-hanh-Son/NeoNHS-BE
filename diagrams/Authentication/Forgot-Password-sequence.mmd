---
config:
  theme: base
  themeVariables:
    primaryColor: "#ffffff"
    primaryTextColor: "#000000"
    primaryBorderColor: "#000000"
    activationBkgColor: "#eeeeee"
    activationBorderColor: "#000000"
    actorBkg: "#ffffff"
    actorTextColor: "#000000"
    actorBorder: "#000000"
    altBackground: "#f5f5f5"
    altBorder: "#000000"
  sequence:
    actorMargin: 10
    messageMargin: 0
---
sequenceDiagram
    actor Tourist as Tourist <br/> <<user>>
    participant ForgotPasswordPage as ForgotPasswordPage <br/> <<user interaction>>
    participant AuthController as AuthController <br/> <<coordinator>>
    participant AuthService as AuthService <br/> <<service>>
    participant UserRepository as UserRepository <br/> <<repository>>
    participant User as User <br/> <<entity>>
    participant DB
    participant PasswordEncoder as PasswordEncoder <br/> <<service>>
    participant RedisAuthService as RedisAuthService <br/> <<service>>
    participant MailService as MailService <br/> <<service>>

    %% Phase 1: Request OTP
    Tourist->>+ForgotPasswordPage: 1. Fills email and request OTP
    ForgotPasswordPage->>+AuthController: 2. forgotPassword(request)
    AuthController->>+AuthService: 3. sendResetPasswordOtp(email)

    AuthService->>+UserRepository: 4. findByEmail(email)
    UserRepository->>+DB: 5. findByEmail(email)
    DB-->>-UserRepository: 6. User result
    UserRepository-->>-AuthService: 7. User result

    alt 8A User not found
        AuthService-->>AuthController: 8A1. User not found
        AuthController-->>ForgotPasswordPage: 8A2. Error response
        ForgotPasswordPage-->>Tourist: 8A3. Show error message
    else 8B User found
        AuthService->>AuthService: 8B1. generateVerifyToken()
        AuthService->>+RedisAuthService: 8B2. saveOtp(email, otp)
        RedisAuthService-->>-AuthService: 8B3. OTP saved successfully
        AuthService->>+MailService: 8B4. sendVerifyEmailAsync(user, template, otp, appUrl)
        MailService-->>-AuthService: 8B5. Email sending task queued
    end

    AuthService-->>-AuthController: 9. Reset password email sent
    AuthController-->>-ForgotPasswordPage: 10. Reset password email sent
    ForgotPasswordPage-->>-Tourist: 11. Show success message and prompt for OTP / New Password

    %% Phase 2: Reset Password
    Tourist->>+ForgotPasswordPage: 12. Submit new password form
    ForgotPasswordPage->>+AuthController: 13. resetPassword(request)
    AuthController->>+AuthService: 14. resetPassword(email, newPassword, confirmPassword)

    AuthService->>AuthService: 15. validatePassword(newPassword, confirmPassword)

    alt 16A Validation failed
        AuthService-->>AuthController: 16A1. throw ValidationException
        AuthController-->>ForgotPasswordPage: 16A2. Error response
        ForgotPasswordPage-->>Tourist: 16A3. Show validation error message
    else 16B Validation passed
        AuthService->>+UserRepository: 16B1. findByEmail(email)
        UserRepository->>+DB: 16B2. findByEmail(email)
        DB-->>-UserRepository: 16B3. User result
        UserRepository-->>-AuthService: 16B4. User entity

        AuthService->>+PasswordEncoder: 16B5. encode(newPassword)
        PasswordEncoder-->>-AuthService: 16B6. Encoded password

        AuthService->>+User: 16B7. updatePassword(encodedPassword)
        User-->>-AuthService: 16B8. Updated user entity
    end

    AuthService-->>-AuthController: 17. Password reset successfully
    AuthController-->>-ForgotPasswordPage: 18. Password reset successfully
    ForgotPasswordPage-->>-Tourist: 19. Show success message and redirect to login
