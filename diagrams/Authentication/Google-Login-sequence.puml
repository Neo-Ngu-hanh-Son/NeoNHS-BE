@startuml
actor Tourist <<user>>
participant GoogleLoginPage <<user interaction>>
participant AuthController <<coordinator>>
participant AuthService <<service>>
participant GoogleTokenVerifier <<service>>
participant DB <<database>>
participant PasswordEncoder <<service>>
participant JwtTokenProvider <<service>>
participant RedisAuthService <<service>>

Tourist -> GoogleLoginPage: 1. Sign in with Google
activate GoogleLoginPage

GoogleLoginPage -> AuthController: 2. googleLogin(idToken)
activate AuthController

AuthController -> AuthService: 3. googleLogin(idToken)
activate AuthService

AuthService -> GoogleTokenVerifier: 4. verify(idToken)
activate GoogleTokenVerifier
GoogleTokenVerifier --> AuthService: 5. GoogleIdToken.Payload
deactivate GoogleTokenVerifier

alt 5A1 Google verification failed
    AuthService --> AuthController: 5A1.1. throw BadRequestException("Google login failed")
    AuthController --> GoogleLoginPage: 5A1.2. Error response
    GoogleLoginPage --> Tourist: 5A1.3. Show Google login error
end

AuthService -> DB: 6. findByEmail(email)
activate DB
DB --> AuthService: 7. Optional<User>
deactivate DB

alt 7A1 User not found
    AuthService -> AuthService: 7A1.1. createUserFromGooglePayload(result)
    activate AuthService
    
    AuthService -> PasswordEncoder: 7A1.2. encode("google_oauth2_user")
    activate PasswordEncoder
    PasswordEncoder --> AuthService: 7A1.3. Hashed password
    deactivate PasswordEncoder
    
    AuthService -> DB: 7A1.4. save(user)
    activate DB
    DB --> AuthService: 7A1.5. Saved User entity
    deactivate DB
    
    deactivate AuthService
end

AuthService -> AuthService: 8. create authentication
activate AuthService
deactivate AuthService

AuthService -> JwtTokenProvider: 9. generateToken(authentication)
activate JwtTokenProvider
JwtTokenProvider --> AuthService: 10. accessToken
deactivate JwtTokenProvider

AuthService -> JwtTokenProvider: 11. generateRefreshToken()
activate JwtTokenProvider
JwtTokenProvider --> AuthService: 12. refreshToken
deactivate JwtTokenProvider

AuthService -> RedisAuthService: 13. saveRefreshToken(refreshToken, userId, uuid)
activate RedisAuthService
RedisAuthService --> AuthService: 14. Saved successfully
deactivate RedisAuthService

AuthService --> AuthController: 15. Return AuthResponse
deactivate AuthService

AuthController --> GoogleLoginPage: 16. Return 200 OK and ApiResponse(AuthResponse)
deactivate AuthController

GoogleLoginPage --> Tourist: 17. Show success and redirect
deactivate GoogleLoginPage
@enduml
