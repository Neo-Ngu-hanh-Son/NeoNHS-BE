---
config:
  theme: base
  themeVariables:
    primaryColor: "#ffffff"
    primaryTextColor: "#000000"
    primaryBorderColor: "#000000"
    activationBkgColor: "#eeeeee"
    activationBorderColor: "#000000"
    actorBkg: "#ffffff"
    actorTextColor: "#000000"
    actorBorder: "#000000"
    altBackground: "#f5f5f5"
    altBorder: "#000000"
  sequence:
    actorMargin: 10
    messageMargin: 0
---
sequenceDiagram
    actor Tourist as Tourist <br/> <<user>>
    participant ViewMapPage as ViewMapPage <br/> <<user interaction>>
    participant PointController as PointController <br/> <<controller>>
    participant PointService as PointService <br/> <<service>>
    participant AttractionRepository as AttractionRepository <br/> <<repository>>
    participant PointRepository as PointRepository <br/> <<repository>>
    participant DB

    Tourist->>+ViewMapPage: 1. Explore attraction map
    ViewMapPage->>+PointController: 2. getPointsByAttraction(attractionId)
    PointController->>+PointService: 3. getPointsByAttraction(attractionId)
    
    PointService->>+AttractionRepository: 4. isAttractionExists(attractionId)
    AttractionRepository->>+DB: 5. isAttractionExists(attractionId)
    DB-->>-AttractionRepository: 6. Returns existence status
    AttractionRepository-->>-PointService: 7. Returns existence status

    alt 8A Attraction not found
        PointService-->>PointController: 8A1. Exception: Attraction not found
        PointController-->>ViewMapPage: 8A2. Error response
        ViewMapPage-->>Tourist: 8A3. Show error message
    else 8B Attraction found
        PointService->>+PointRepository: 8B1. findPointsByAttractionId(attractionId)
        PointRepository->>+DB: 8B2. Find points by attraction ID
        DB-->>-PointRepository: 8B3. List of Point entities
        PointRepository-->>-PointService: 8B4. List of Point entities
        PointService->>PointService: 8B5. mapToRespones()
        PointService-->>-PointController: 8B6. List of PointResponses
        PointController-->>-ViewMapPage: 8B7. List of PointResponses
        ViewMapPage-->>-Tourist: 8B8. Display markers on map
    end
