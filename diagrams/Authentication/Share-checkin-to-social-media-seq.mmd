---
config:
  theme: base
  themeVariables:
    primaryColor: "#ffffff"
    primaryTextColor: "#000000"
    primaryBorderColor: "#000000"
    activationBkgColor: "#eeeeee"
    activationBorderColor: "#000000"
    actorBkg: "#ffffff"
    actorTextColor: "#000000"
    actorBorder: "#000000"
    altBackground: "#f5f5f5"
    altBorder: "#000000"
  sequence:
    actorMargin: 10
    messageMargin: 0
---
sequenceDiagram
    actor Tourist as Tourist <br/> <<user>>
    participant MapScreen as MapScreen <br/> <<user interaction>>
    participant PointController as PointController <br/> <<controller>>
    participant PointService as PointService <br/> <<service>>
    participant UserCheckinPointRepository as UserCheckinPointRepository <br/> <<repository>>
    participant DB
    participant SocialMediaApp as SocialMediaApp <br/> <<external system>>

    Tourist->>+MapScreen: 1. Click "Share Check-in"
    MapScreen->>+PointController: 2. generateShareLink(checkinId)
    PointController->>+PointService: 3. generateShareLink(checkinId)
    PointService->>+UserCheckinPointRepository: 4. findCheckinById(checkinId)
    UserCheckinPointRepository->>+DB: 5. findCheckinById(checkinId)
    DB-->>-UserCheckinPointRepository: 6. Check-in entity
    UserCheckinPointRepository-->>-PointService: 7. Check-in entity

    alt 8A Check-in not found
        PointService-->>PointController: 8A1. Exception: Check-in not found
        PointController-->>MapScreen: 8A2. Error response
        MapScreen-->>Tourist: 8A3. Show error message
    else 8B Check-in found
        PointService->>PointService: 8B1. Format shareable link/data
        PointService-->>-PointController: 8B2. Share data response
        PointController-->>-MapScreen: 8B3. Share data response
        
        %% Native sharing behavior
        MapScreen->>+SocialMediaApp: 8B4. Open native share intent (Facebook/Twitter/etc.)
        SocialMediaApp-->>-MapScreen: 8B5. User completes or cancels share
    end
        %% Optional: Recording the share action to give bonus points
        MapScreen->>+PointController: 9. recordShareAction(checkinId, platform)
        PointController->>+PointService: 10. recordShareAction(checkinId, platform)
        PointService->>PointService: 11. Validate share & calculate bonus points
        PointService->>+UserCheckinPointRepository: 12. updatePointStatus(userId, bonus)
        UserCheckinPointRepository->>+DB: 13. updatePointStatus(userId, bonus)
        DB-->>-UserCheckinPointRepository: 14. Updated status
        UserCheckinPointRepository-->>-PointService: 15. Updated status
        PointService-->>-PointController: 16. Share rewarded response
        PointController-->>-MapScreen: 17. Share rewarded response
        MapScreen-->>-Tourist: 18. Show success & reward message
