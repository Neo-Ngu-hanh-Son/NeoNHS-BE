---
title: "API 1 — POST /api/workshops/templates (Create Workshop Template)"
---
classDiagram
    direction LR

    %% ===== Controller Layer =====
    class WorkshopTemplateController {
        -WorkshopTemplateService workshopTemplateService
        +createWorkshopTemplate(request, principal) ResponseEntity~ApiResponse~WorkshopTemplateResponse~~
    }

    %% ===== Service Layer =====
    class WorkshopTemplateService {
        <<interface>>
        +createWorkshopTemplate(email, request) WorkshopTemplateResponse
    }

    class WorkshopTemplateServiceImpl {
        -WorkshopTemplateRepository workshopTemplateRepository
        -WTagRepository wTagRepository
        -VendorProfileRepository vendorProfileRepository
        +createWorkshopTemplate(email, request) WorkshopTemplateResponse
    }

    %% ===== Repository Layer =====
    class WorkshopTemplateRepository {
        <<interface>>
        +save(entity) WorkshopTemplate
    }

    class WTagRepository {
        <<interface>>
        +findAllByIdIn(ids) List~WTag~
    }

    class VendorProfileRepository {
        <<interface>>
        +findByUserEmail(email) Optional~VendorProfile~
    }

    %% ===== Request DTO =====
    class CreateWorkshopTemplateRequest {
        +String name
        +String shortDescription
        +String fullDescription
        +BigDecimal defaultPrice
        +Integer estimatedDuration
        +Integer minParticipants
        +Integer maxParticipants
        +List~String~ imageUrls
        +Integer thumbnailIndex
        +List~UUID~ tagIds
    }

    %% ===== Response DTOs =====
    class ApiResponse~T~ {
        +int status
        +boolean success
        +String message
        +T data
        +LocalDateTime timestamp
    }

    class WorkshopTemplateResponse {
        +UUID id
        +String name
        +String shortDescription
        +String fullDescription
        +Integer estimatedDuration
        +BigDecimal defaultPrice
        +Integer minParticipants
        +Integer maxParticipants
        +WorkshopStatus status
        +Boolean isPublished
        +BigDecimal averageRating
        +Integer totalRatings
        +UUID vendorId
        +String vendorName
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
        +String adminNote
        +UUID reviewedBy
        +LocalDateTime reviewedAt
        +List~WorkshopImageResponse~ images
        +List~WTagResponse~ tags
    }

    class WorkshopImageResponse {
        +UUID id
        +String imageUrl
        +Boolean isThumbnail
    }

    class WTagResponse {
        +UUID id
        +String name
        +String description
        +String tagColor
        +String iconUrl
    }

    %% ===== Entity Layer =====
    class WorkshopTemplate {
        +UUID id
        +String name
        +String shortDescription
        +String fullDescription
        +Integer estimatedDuration
        +BigDecimal defaultPrice
        +Integer minParticipants
        +Integer maxParticipants
        +WorkshopStatus status
        +Boolean isPublished
        +BigDecimal averageRating
        +Integer totalRatings
        +String adminNote
        +UUID reviewedBy
        +LocalDateTime reviewedAt
    }

    class VendorProfile {
        +UUID id
        +String businessName
        +Boolean isVerified
    }

    class WorkshopImage {
        +UUID id
        +String imageUrl
        +Boolean isThumbnail
    }

    class WTag {
        +UUID id
        +String name
        +String description
        +String tagColor
        +String iconUrl
    }

    class WorkshopTag {
        +WorkshopTagId id
    }

    class WorkshopTagId {
        +UUID workshopId
        +UUID wTagId
    }

    %% ===== Enums =====
    class WorkshopStatus {
        <<enumeration>>
        DRAFT
        PENDING
        ACTIVE
        REJECTED
    }

    %% ===== Relationships =====

    %% Controller → Service
    WorkshopTemplateController --> WorkshopTemplateService : uses
    WorkshopTemplateController ..> CreateWorkshopTemplateRequest : receives
    WorkshopTemplateController ..> ApiResponse : returns

    %% Service implementation
    WorkshopTemplateServiceImpl ..|> WorkshopTemplateService : implements
    WorkshopTemplateServiceImpl --> WorkshopTemplateRepository : uses
    WorkshopTemplateServiceImpl --> WTagRepository : uses
    WorkshopTemplateServiceImpl --> VendorProfileRepository : uses
    WorkshopTemplateServiceImpl ..> WorkshopTemplateResponse : returns

    %% Repository → Entity
    WorkshopTemplateRepository ..> WorkshopTemplate : manages
    WTagRepository ..> WTag : manages
    VendorProfileRepository ..> VendorProfile : manages

    %% Entity relationships
    WorkshopTemplate --> VendorProfile : vendor (ManyToOne)
    WorkshopTemplate "1" --> "*" WorkshopImage : workshopImages (OneToMany, cascade)
    WorkshopTemplate "1" --> "*" WorkshopTag : workshopTags (OneToMany, cascade)
    WorkshopTag --> WTag : wTag (ManyToOne)
    WorkshopTag --> WorkshopTagId : id (EmbeddedId)
    WorkshopTemplate --> WorkshopStatus : status

    %% Response composition
    ApiResponse --> WorkshopTemplateResponse : data
    WorkshopTemplateResponse --> "*" WorkshopImageResponse : images
    WorkshopTemplateResponse --> "*" WTagResponse : tags
