---
title: "API 3 — GET /api/workshops/templates/my (Get My Workshop Templates — Paginated)"
---
classDiagram
    direction LR

    %% ===== Controller Layer =====
    class WorkshopTemplateController {
        -WorkshopTemplateService workshopTemplateService
        +getMyWorkshopTemplates(principal, page, size, sortBy, sortDir) ResponseEntity~ApiResponse~Page~WorkshopTemplateResponse~~~
    }

    %% ===== Service Layer =====
    class WorkshopTemplateService {
        <<interface>>
        +getMyWorkshopTemplates(email, pageable) Page~WorkshopTemplateResponse~
    }

    class WorkshopTemplateServiceImpl {
        -WorkshopTemplateRepository workshopTemplateRepository
        -VendorProfileRepository vendorProfileRepository
        +getMyWorkshopTemplates(email, pageable) Page~WorkshopTemplateResponse~
    }

    %% ===== Repository Layer =====
    class WorkshopTemplateRepository {
        <<interface>>
        +findByVendorId(vendorId, pageable) Page~WorkshopTemplate~
    }

    class VendorProfileRepository {
        <<interface>>
        +findByUserEmail(email) Optional~VendorProfile~
    }

    %% ===== Pagination =====
    class PaginationConstants {
        +String DEFAULT_PAGE = "0"
        +String DEFAULT_SIZE = "10"
        +String DEFAULT_SORT_BY = "createdAt"
        +String DEFAULT_SORT_DIR = "desc"
        +String SORT_ASC = "asc"
        +int MAX_PAGE_SIZE = 100
    }

    class Page~T~ {
        <<interface>>
        +List~T~ content
        +int totalPages
        +long totalElements
        +int number
        +int size
        +boolean first
        +boolean last
    }

    class Pageable {
        <<interface>>
        +int pageNumber
        +int pageSize
        +Sort sort
    }

    %% ===== Response DTOs =====
    class ApiResponse~T~ {
        +int status
        +boolean success
        +String message
        +T data
        +LocalDateTime timestamp
    }

    class WorkshopTemplateResponse {
        +UUID id
        +String name
        +String shortDescription
        +String fullDescription
        +Integer estimatedDuration
        +BigDecimal defaultPrice
        +Integer minParticipants
        +Integer maxParticipants
        +WorkshopStatus status
        +Boolean isPublished
        +BigDecimal averageRating
        +Integer totalRatings
        +UUID vendorId
        +String vendorName
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
        +String adminNote
        +UUID reviewedBy
        +LocalDateTime reviewedAt
        +List~WorkshopImageResponse~ images
        +List~WTagResponse~ tags
    }

    class WorkshopImageResponse {
        +UUID id
        +String imageUrl
        +Boolean isThumbnail
    }

    class WTagResponse {
        +UUID id
        +String name
        +String description
        +String tagColor
        +String iconUrl
    }

    %% ===== Entity Layer =====
    class WorkshopTemplate {
        +UUID id
        +String name
        +String shortDescription
        +String fullDescription
        +Integer estimatedDuration
        +BigDecimal defaultPrice
        +Integer minParticipants
        +Integer maxParticipants
        +WorkshopStatus status
        +Boolean isPublished
        +BigDecimal averageRating
        +Integer totalRatings
        +String adminNote
        +UUID reviewedBy
        +LocalDateTime reviewedAt
    }

    class VendorProfile {
        +UUID id
        +String businessName
        +Boolean isVerified
    }

    %% ===== Enums =====
    class WorkshopStatus {
        <<enumeration>>
        DRAFT
        PENDING
        ACTIVE
        REJECTED
    }

    %% ===== Relationships =====

    %% Controller → Service
    WorkshopTemplateController --> WorkshopTemplateService : uses
    WorkshopTemplateController ..> PaginationConstants : reads defaults
    WorkshopTemplateController ..> Pageable : builds from params
    WorkshopTemplateController ..> ApiResponse : returns

    %% Service implementation
    WorkshopTemplateServiceImpl ..|> WorkshopTemplateService : implements
    WorkshopTemplateServiceImpl --> WorkshopTemplateRepository : uses
    WorkshopTemplateServiceImpl --> VendorProfileRepository : uses
    WorkshopTemplateServiceImpl ..> Page : returns

    %% Repository → Entity
    WorkshopTemplateRepository ..> WorkshopTemplate : manages
    WorkshopTemplateRepository ..> Page : returns
    VendorProfileRepository ..> VendorProfile : manages

    %% Entity relationships
    WorkshopTemplate --> VendorProfile : vendor (ManyToOne)
    WorkshopTemplate --> WorkshopStatus : status

    %% Response composition
    ApiResponse --> Page : data wraps Page
    Page --> "*" WorkshopTemplateResponse : content
    WorkshopTemplateResponse --> "*" WorkshopImageResponse : images
    WorkshopTemplateResponse --> "*" WTagResponse : tags
