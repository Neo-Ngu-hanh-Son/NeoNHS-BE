sequenceDiagram
    actor Vendor as Vendor
    participant Page as MyTemplatesPage <<user interaction>>
    participant Controller as WorkshopTemplateController <<coordinator>>
    participant Service as WorkshopTemplateService <<service>>
    participant VendorProfile as VendorProfile <<entity>>
    participant WorkshopTemplate as WorkshopTemplate <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Navigate to "My Workshop Templates" with pagination params
    activate Page
    Page->>Controller: 2. getMyWorkshopTemplates(principal, page, size, sortBy, sortDir)
    activate Controller
    Controller->>Controller: 3. Build Pageable from params (PageRequest.of)
    Controller->>Service: 4. getMyWorkshopTemplates(email, pageable)
    activate Service

    Service->>VendorProfile: 5. findByUserEmail(email)
    activate VendorProfile
    VendorProfile->>DB: 6. SELECT vendor_profile WHERE user.email = ?
    activate DB
    DB-->>VendorProfile: Vendor data
    deactivate DB
    VendorProfile-->>Service: Optional~VendorProfile~
    deactivate VendorProfile

    alt 6A. Vendor not found
        Service-->>Controller: 6A1. ResourceNotFoundException("VendorProfile not found")
        Controller-->>Page: 6A2. 404 Not Found
        Page-->>Vendor: 6A3. Show error: "Vendor profile not found"
    else 6B. Vendor found
        Service->>WorkshopTemplate: 7. findByVendorId(vendorId, pageable)
        activate WorkshopTemplate
        WorkshopTemplate->>DB: 8. SELECT workshop_template WHERE vendor_id = ? (paginated, sorted)
        activate DB
        DB-->>WorkshopTemplate: Page of templates
        deactivate DB
        WorkshopTemplate-->>Service: Page~WorkshopTemplate~
        deactivate WorkshopTemplate

        Service->>Service: 9. Map each template via mapToResponse()
        Service-->>Controller: 10. Page~WorkshopTemplateResponse~
        deactivate Service
        Controller-->>Page: 11. 200 OK + ApiResponse~Page~WorkshopTemplateResponse~~
        deactivate Controller
        Page-->>Vendor: 12. Display paginated template list
        deactivate Page
    end
