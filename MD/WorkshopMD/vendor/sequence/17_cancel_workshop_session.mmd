sequenceDiagram
    actor Vendor as Vendor
    participant Page as SessionManagePage <<user interaction>>
    participant Controller as WorkshopSessionController <<coordinator>>
    participant Service as WorkshopSessionService <<service>>
    participant WorkshopSession as WorkshopSession <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Click "Cancel Session" and confirm
    activate Page
    Page->>Controller: 2. cancelWorkshopSession(id, principal)
    activate Controller
    Controller->>Service: 3. cancelWorkshopSession(email, id)
    activate Service

    Service->>WorkshopSession: 4. findById(id)
    activate WorkshopSession
    WorkshopSession->>DB: 5. SELECT workshop_session WHERE id = ?
    activate DB
    DB-->>WorkshopSession: Session data
    deactivate DB
    WorkshopSession-->>Service: Optional~WorkshopSession~
    deactivate WorkshopSession

    alt 5A. Session not found
        Service-->>Controller: 5A1. ResourceNotFoundException("WorkshopSession not found")
        Controller-->>Page: 5A2. 404 Not Found
        Page-->>Vendor: 5A3. Show error: "Session does not exist"
    else 5B. Session found
        Service->>Service: 6. Check ownership and SCHEDULED status

        alt 6A. Not owner or session not SCHEDULED
            Service-->>Controller: 6A1. BadRequestException (ownership or status violation)
            Controller-->>Page: 6A2. 403 / 400 Error
            Page-->>Vendor: 6A3. Show error message
        else 6B. Owner confirmed and session is SCHEDULED
            Service->>Service: 7. Set status = CANCELLED
            Service->>WorkshopSession: 8. save(session)
            activate WorkshopSession
            WorkshopSession->>DB: 9. UPDATE workshop_session SET status = 'CANCELLED'
            activate DB
            DB-->>WorkshopSession: Updated entity
            deactivate DB
            WorkshopSession-->>Service: WorkshopSession (cancelled)
            deactivate WorkshopSession

            Service->>Service: 10. mapToResponse(cancelledSession)
            Service-->>Controller: 11. WorkshopSessionResponse
            deactivate Service
            Controller-->>Page: 12. 200 OK + ApiResponse~WorkshopSessionResponse~
            deactivate Controller
            Page-->>Vendor: 13. Show success: "Session cancelled"
            deactivate Page
        end
    end
