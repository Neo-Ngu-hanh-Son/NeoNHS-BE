sequenceDiagram
    actor Vendor as Vendor
    participant Page as TemplateManagePage <<user interaction>>
    participant Controller as WorkshopTemplateController <<coordinator>>
    participant Service as WorkshopTemplateService <<service>>
    participant WorkshopTemplate as WorkshopTemplate <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Click "Submit for Review" on a DRAFT or REJECTED template
    activate Page
    Page->>Controller: 2. submitTemplateForApproval(id, principal)
    activate Controller
    Controller->>Service: 3. submitTemplateForApproval(id, email)
    activate Service

    Service->>WorkshopTemplate: 4. findById(id)
    activate WorkshopTemplate
    WorkshopTemplate->>DB: 5. SELECT workshop_template WHERE id = ?
    activate DB
    DB-->>WorkshopTemplate: Template data
    deactivate DB
    WorkshopTemplate-->>Service: Optional~WorkshopTemplate~
    deactivate WorkshopTemplate

    alt 5A. Template not found
        Service-->>Controller: 5A1. ResourceNotFoundException("WorkshopTemplate not found")
        Controller-->>Page: 5A2. 404 Not Found
        Page-->>Vendor: 5A3. Show error: "Template does not exist"
    else 5B. Template found
        Service->>Service: 6. Check ownership and submittable status (DRAFT or REJECTED)

        alt 6A. Not owner or status is PENDING / ACTIVE
            Service-->>Controller: 6A1. ForbiddenException / BadRequestException
            Controller-->>Page: 6A2. 403 / 400 Error
            Page-->>Vendor: 6A3. Show error message
        else 6B. Owner confirmed and status allows submission
            Service->>Service: 7. Validate completeness (name, description, price, duration, participants, image, tags)

            alt 7A. Template incomplete
                Service-->>Controller: 7A1. BadRequestException("Template is missing required fields")
                Controller-->>Page: 7A2. 400 Bad Request
                Page-->>Vendor: 7A3. Show error: "Complete all required fields before submitting"
            else 7B. Template complete
                Service->>Service: 8. Set status = PENDING
                Service->>WorkshopTemplate: 9. save(workshopTemplate)
                activate WorkshopTemplate
                WorkshopTemplate->>DB: 10. UPDATE workshop_template SET status = 'PENDING'
                activate DB
                DB-->>WorkshopTemplate: Updated entity
                deactivate DB
                WorkshopTemplate-->>Service: WorkshopTemplate (updated)
                deactivate WorkshopTemplate

                Service->>Service: 11. mapToResponse(updatedTemplate)
                Service-->>Controller: 12. WorkshopTemplateResponse
                deactivate Service
                Controller-->>Page: 13. 200 OK + ApiResponse~WorkshopTemplateResponse~
                deactivate Controller
                Page-->>Vendor: 14. Show success: "Template submitted for admin review"
                deactivate Page
            end
        end
    end
