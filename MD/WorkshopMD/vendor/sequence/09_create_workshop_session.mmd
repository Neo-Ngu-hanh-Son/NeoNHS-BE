sequenceDiagram
    actor Vendor as Vendor
    participant Page as CreateSessionPage <<user interaction>>
    participant Controller as WorkshopSessionController <<coordinator>>
    participant Service as WorkshopSessionService <<service>>
    participant WorkshopTemplate as WorkshopTemplate <<entity>>
    participant WorkshopSession as WorkshopSession <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Fill in session details (template, time, price, capacity) and submit
    activate Page
    Page->>Controller: 2. createWorkshopSession(request, principal)
    activate Controller
    Controller->>Service: 3. createWorkshopSession(email, request)
    activate Service

    Service->>WorkshopTemplate: 4. findById(workshopTemplateId)
    activate WorkshopTemplate
    WorkshopTemplate->>DB: 5. SELECT workshop_template WHERE id = ?
    activate DB
    DB-->>WorkshopTemplate: Template data
    deactivate DB
    WorkshopTemplate-->>Service: Optional~WorkshopTemplate~
    deactivate WorkshopTemplate

    alt 5A. Template not found, not ACTIVE, or not owned by vendor
        Service-->>Controller: 5A1. ResourceNotFoundException / BadRequestException
        Controller-->>Page: 5A2. 404 / 400 Error
        Page-->>Vendor: 5A3. Show error message
    else 5B. Template found, ACTIVE, and owned by vendor
        Service->>Service: 6. Validate time constraints (startTime in future, endTime after startTime)
        Service->>Service: 7. Resolve defaults and validate maxParticipants >= template minParticipants

        alt 7A. Validation fails
            Service-->>Controller: 7A1. BadRequestException (time or participant constraint)
            Controller-->>Page: 7A2. 400 Bad Request
            Page-->>Vendor: 7A3. Show validation error
        else 7B. All valid
            Service->>Service: 8. Build WorkshopSession entity (status = SCHEDULED, currentEnrolled = 0)
            Service->>WorkshopSession: 9. save(session)
            activate WorkshopSession
            WorkshopSession->>DB: 10. INSERT workshop_session
            activate DB
            DB-->>WorkshopSession: Saved entity with generated ID
            deactivate DB
            WorkshopSession-->>Service: WorkshopSession (saved)
            deactivate WorkshopSession

            Service->>Service: 11. mapToResponse(savedSession)
            Service-->>Controller: 12. WorkshopSessionResponse
            deactivate Service
            Controller-->>Page: 13. 201 Created + ApiResponse~WorkshopSessionResponse~
            deactivate Controller
            Page-->>Vendor: 14. Show success: "Session scheduled successfully"
            deactivate Page
        end
    end
