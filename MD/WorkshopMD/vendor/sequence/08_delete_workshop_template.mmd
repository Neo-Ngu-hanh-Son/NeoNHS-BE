sequenceDiagram
    actor Vendor as Vendor
    participant Page as TemplateManagePage <<user interaction>>
    participant Controller as WorkshopTemplateController <<coordinator>>
    participant Service as WorkshopTemplateService <<service>>
    participant WorkshopTemplate as WorkshopTemplate <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Click "Delete Template" and confirm
    activate Page
    Page->>Controller: 2. deleteWorkshopTemplate(id, principal)
    activate Controller
    Controller->>Service: 3. deleteWorkshopTemplate(id, email)
    activate Service

    Service->>WorkshopTemplate: 4. findById(id)
    activate WorkshopTemplate
    WorkshopTemplate->>DB: 5. SELECT workshop_template WHERE id = ?
    activate DB
    DB-->>WorkshopTemplate: Template data
    deactivate DB
    WorkshopTemplate-->>Service: Optional~WorkshopTemplate~
    deactivate WorkshopTemplate

    alt 5A. Template not found
        Service-->>Controller: 5A1. ResourceNotFoundException("WorkshopTemplate not found")
        Controller-->>Page: 5A2. 404 Not Found
        Page-->>Vendor: 5A3. Show error: "Template does not exist"
    else 5B. Template found
        Service->>Service: 6. Check ownership and deletable status (not ACTIVE)

        alt 6A. Not owner or template is ACTIVE
            Service-->>Controller: 6A1. ForbiddenException / BadRequestException
            Controller-->>Page: 6A2. 403 / 400 Error
            Page-->>Vendor: 6A3. Show error message
        else 6B. Owner confirmed and status allows deletion
            Service->>WorkshopTemplate: 7. delete(workshopTemplate)
            activate WorkshopTemplate
            WorkshopTemplate->>DB: 8. DELETE workshop_template, images, tag associations (cascade)
            activate DB
            DB-->>WorkshopTemplate: Deletion confirmed
            deactivate DB
            deactivate WorkshopTemplate

            Service-->>Controller: 9. void (success)
            deactivate Service
            Controller-->>Page: 10. 200 OK + ApiResponse~"Template deleted successfully"~
            deactivate Controller
            Page-->>Vendor: 11. Show success and redirect to template list
            deactivate Page
        end
    end
