sequenceDiagram
    actor Vendor as Vendor
    participant Page as TemplateEditPage <<user interaction>>
    participant Controller as WorkshopTemplateController <<coordinator>>
    participant Service as WorkshopTemplateService <<service>>
    participant WorkshopTemplate as WorkshopTemplate <<entity>>
    participant WTag as WTag <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Edit template fields and submit update
    activate Page
    Page->>Controller: 2. updateWorkshopTemplate(id, request, principal)
    activate Controller
    Controller->>Service: 3. updateWorkshopTemplate(id, email, request)
    activate Service

    Service->>WorkshopTemplate: 4. findById(id)
    activate WorkshopTemplate
    WorkshopTemplate->>DB: 5. SELECT workshop_template WHERE id = ?
    activate DB
    DB-->>WorkshopTemplate: Template data
    deactivate DB
    WorkshopTemplate-->>Service: Optional~WorkshopTemplate~
    deactivate WorkshopTemplate

    alt 5A. Template not found
        Service-->>Controller: 5A1. ResourceNotFoundException("WorkshopTemplate not found")
        Controller-->>Page: 5A2. 404 Not Found
        Page-->>Vendor: 5A3. Show error: "Template does not exist"
    else 5B. Template found
        Service->>Service: 6. Check ownership and editable status (DRAFT or REJECTED)

        alt 6A. Not owner or status is PENDING / ACTIVE
            Service-->>Controller: 6A1. ForbiddenException / BadRequestException
            Controller-->>Page: 6A2. 403 / 400 Error
            Page-->>Vendor: 6A3. Show error message
        else 6B. Owner confirmed and status allows editing
            Service->>WTag: 7. findAllByIdIn(tagIds)
            activate WTag
            WTag->>DB: 8. SELECT w_tag WHERE id IN (?)
            activate DB
            DB-->>WTag: List of WTag
            deactivate DB
            WTag-->>Service: List~WTag~
            deactivate WTag

            Service->>Service: 9. Validate inputs (participants range, tag IDs, thumbnail index)

            alt 9A. Validation fails
                Service-->>Controller: 9A1. BadRequestException (validation error detail)
                Controller-->>Page: 9A2. 400 Bad Request
                Page-->>Vendor: 9A3. Show validation error
            else 9B. All valid
                Service->>Service: 10. Apply field updates and replace image / tag associations

                Service->>WorkshopTemplate: 11. save(workshopTemplate)
                activate WorkshopTemplate
                WorkshopTemplate->>DB: 12. UPDATE workshop_template, images, tags
                activate DB
                DB-->>WorkshopTemplate: Updated entity
                deactivate DB
                WorkshopTemplate-->>Service: WorkshopTemplate (updated)
                deactivate WorkshopTemplate

                Service->>Service: 13. mapToResponse(updatedTemplate)
                Service-->>Controller: 14. WorkshopTemplateResponse
                deactivate Service
                Controller-->>Page: 15. 200 OK + ApiResponse~WorkshopTemplateResponse~
                deactivate Controller
                Page-->>Vendor: 16. Show success: "Template updated successfully"
                deactivate Page
            end
        end
    end
