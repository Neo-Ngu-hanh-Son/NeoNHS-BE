sequenceDiagram
    actor Vendor as Vendor
    participant Page as CreateTemplatePage <<user interaction>>
    participant Controller as WorkshopTemplateController <<coordinator>>
    participant Service as WorkshopTemplateService <<service>>
    participant VendorProfile as VendorProfile <<entity>>
    participant WTag as WTag <<entity>>
    participant WorkshopTemplate as WorkshopTemplate <<entity>>
    participant DB as DB

    Vendor->>Page: 1. Fill in template details and submit
    activate Page
    Page->>Controller: 2. createWorkshopTemplate(request, principal)
    activate Controller
    Controller->>Service: 3. createWorkshopTemplate(email, request)
    activate Service

    Service->>VendorProfile: 4. findByUserEmail(email)
    activate VendorProfile
    VendorProfile->>DB: 5. SELECT vendor_profile WHERE user.email = ?
    activate DB
    DB-->>VendorProfile: Vendor data
    deactivate DB
    VendorProfile-->>Service: Optional~VendorProfile~
    deactivate VendorProfile

    alt 5A. Vendor not found or not verified
        Service-->>Controller: 5A1. ResourceNotFoundException / BadRequestException
        Controller-->>Page: 5A2. 404 / 400 Error
        Page-->>Vendor: 5A3. Show error message
    else 5B. Vendor found and verified
        Service->>WTag: 6. findAllByIdIn(tagIds)
        activate WTag
        WTag->>DB: 7. SELECT w_tag WHERE id IN (?)
        activate DB
        DB-->>WTag: List of WTag
        deactivate DB
        WTag-->>Service: List~WTag~
        deactivate WTag

        Service->>Service: 8. Validate inputs (participants range, tag IDs, thumbnail index)

        alt 8A. Validation fails
            Service-->>Controller: 8A1. BadRequestException (validation error detail)
            Controller-->>Page: 8A2. 400 Bad Request
            Page-->>Vendor: 8A3. Show validation error
        else 8B. All valid
            Service->>Service: 9. Build WorkshopTemplate entity (status = DRAFT)
            Service->>Service: 10. Build WorkshopImage and WorkshopTag join entities

            Service->>WorkshopTemplate: 11. save(workshopTemplate)
            activate WorkshopTemplate
            WorkshopTemplate->>DB: 12. INSERT workshop_template, images, tags
            activate DB
            DB-->>WorkshopTemplate: Saved entity with generated ID
            deactivate DB
            WorkshopTemplate-->>Service: WorkshopTemplate (saved)
            deactivate WorkshopTemplate

            Service->>Service: 13. mapToResponse(savedTemplate, tags)
            Service-->>Controller: 14. WorkshopTemplateResponse
            deactivate Service
            Controller-->>Page: 15. 201 Created + ApiResponse~WorkshopTemplateResponse~
            deactivate Controller
            Page-->>Vendor: 16. Show success: "Template created in DRAFT status"
            deactivate Page
        end
    end
